---
---
<section id="about" class="section about-section">
  <!-- Decorative Background Typography -->
  <div class="bg-typography">ABOUT</div>
  <div class="bg-orb orb-1"></div>
  <div class="bg-orb orb-2"></div>

  <div class="container relative-z">
    <div class="about-top-row fade-in">
      <div class="about-header">
        <h2 class="section-title">The Mind Behind the <span class="text-accent">Models</span></h2>
        <p class="subtitle">Exploring the cosmos through the lens of artificial intelligence.</p>
      </div>
      
      <!-- Code Terminal -->
      <div class="code-window glass">
        <div class="code-header">
          <div class="dots">
            <span class="dot red"></span>
            <span class="dot yellow"></span>
            <span class="dot green"></span>
          </div>
          <span class="file-name">engineer.py</span>
        </div>
        <pre><code><span class="keyword">class</span> <span class="entity">MLEngineerResearcher</span>:
    <span class="keyword">def</span> <span class="function">__init__</span>(<span class="variable">self</span>):
        <span class="variable">self</span>.role = <span class="string">"AI for Science & Society"</span>
        <span class="variable">self</span>.stack = [<span class="string">"Deep Learning"</span>, <span class="string">"GenAI"</span>, <span class="string">"MLOps"</span>]
        
    <span class="keyword">def</span> <span class="function">build_future</span>(<span class="variable">self</span>):
        <span class="keyword">while</span> <span class="constant">True</span>:
            <span class="keyword">yield</span> <span class="variable">self</span>.innovate()</code></pre>
      </div>
    </div>
    
    <!-- Row 2: Narrative Panels -->
    <div class="about-narrative-row fade-in">
      <div class="glass narrative-panel">
        <h3>My Journey</h3>
        <p>
          I earned my degree in <strong>Civil Industrial Engineering</strong> and later a <strong>Master's in Computer Science</strong> from the Universidad de Concepción. 
          During my master's, I completed two pivotal 3-4 month research internships at <strong>Harvard University</strong> in Boston. This experience yielded several publications in prominent journals and top-tier conference workshops, further solidifying my commitment to scientific discovery and honing my technical expertise.
        </p>
      </div>

      <div class="glass narrative-panel highlight-border">
        <h3>Current Focus & Vision</h3>
        <p>
          Currently, I deploy AI for real-world scientific discovery as an ML Engineer at <strong>ALeRCE</strong>, while continuously expanding my horizons. I am actively learning more about the startup ecosystem, large-scale generative AI applications, and agentic automation.
        </p>
        <p style="margin-top: 1rem;">
          My ultimate goal is to design robust and reliable AI systems that contribute to science and society, while mentoring the next generation of researchers from the Global South. I am always open to contributing to high-impact research, open-source technology, and collaborative projects.
        </p>
      </div>
    </div>

    <!-- Arsenal Inside Main Block -->
    <div class="about-skills-row fade-in">
      <h3 class="skills-inline-title">Arsenal & Tech Stack</h3>
      
      <div class="skills-grid">
        <!-- Category 1 -->
        <div class="skill-category glass">
          <div class="category-header">
            <svg class="category-icon" viewBox="0 0 24 24" fill="none" stroke="var(--color-accent)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2v20M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"></path></svg>
            <h4>Deep Learning & AI</h4>
          </div>
          <div class="skill-tags">
            <span class="tag">PyTorch</span>
            <span class="tag">TensorFlow</span>
            <span class="tag">Hugging Face</span>
            <span class="tag">OpenAI</span>
            <span class="tag">Anthropic</span>
            <span class="tag">Transformers</span>
          </div>
        </div>

        <!-- Category 2 -->
        <div class="skill-category glass">
          <div class="category-header">
            <svg class="category-icon" viewBox="0 0 24 24" fill="none" stroke="var(--color-accent)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"></path></svg>
            <h4>RAG & Agents</h4>
          </div>
          <div class="skill-tags">
            <span class="tag">LangChain</span>
            <span class="tag">LlamaIndex</span>
            <span class="tag">Pinecone</span>
            <span class="tag">Milvus</span>
            <span class="tag">pgvector</span>
          </div>
        </div>

        <!-- Category 3 -->
        <div class="skill-category glass">
          <div class="category-header">
            <svg class="category-icon" viewBox="0 0 24 24" fill="none" stroke="var(--color-accent)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><ellipse cx="12" cy="5" rx="9" ry="3"></ellipse><path d="M21 12c0 1.66-4 3-9 3s-9-1.34-9-3"></path><path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5"></path></svg>
            <h4>Data Engineering</h4>
          </div>
          <div class="skill-tags">
            <span class="tag">SQL / BigQuery</span>
            <span class="tag">Apache Spark</span>
            <span class="tag">Kafka</span>
            <span class="tag">Airflow</span>
            <span class="tag">dbt</span>
          </div>
        </div>

        <!-- Category 4 -->
        <div class="skill-category glass">
          <div class="category-header">
            <svg class="category-icon" viewBox="0 0 24 24" fill="none" stroke="var(--color-accent)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="8" rx="2" ry="2"></rect><rect x="2" y="14" width="20" height="8" rx="2" ry="2"></rect><line x1="6" y1="6" x2="6.01" y2="6"></line><line x1="6" y1="18" x2="6.01" y2="18"></line></svg>
            <h4>MLOps & Cloud</h4>
          </div>
          <div class="skill-tags">
            <span class="tag">AWS / GCP</span>
            <span class="tag">Docker</span>
            <span class="tag">Kubernetes</span>
            <span class="tag">MLflow</span>
            <span class="tag">GitHub Actions</span>
            <span class="tag">FastAPI</span>
          </div>
        </div>
      </div>
    </div>

    <!-- Travels & Exploration Section -->

    <div class="explorer-header fade-in">
      <h2 class="section-title">Beyond the <span class="text-accent">Code</span></h2>
      <p class="subtitle">Exploring the world fuels my creativity for exploring the universe's data.</p>
    </div>

      <div class="travel-gallery">
        <!-- Travel Card 1 -->
        <div class="travel-card glass">
          <div class="card-inner">
            <img src="https://images.unsplash.com/photo-1506521781263-d8422e82f27a?auto=format&fit=crop&w=600&q=80" alt="Boston" loading="lazy" />
            <div class="travel-location">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--color-accent)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path><circle cx="12" cy="10" r="3"></circle></svg>
              Boston, USA
            </div>
          </div>
        </div>

        <!-- Travel Card 2 -->
        <div class="travel-card glass">
          <div class="card-inner">
            <img src="https://images.unsplash.com/photo-1451187580459-43490279c0fa?auto=format&fit=crop&w=600&q=80" alt="Atacama" loading="lazy" />
            <div class="travel-location">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--color-accent)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path><circle cx="12" cy="10" r="3"></circle></svg>
              Atacama Desert, Chile
            </div>
          </div>
        </div>

        <!-- Travel Card 3 -->
        <div class="travel-card glass">
          <div class="card-inner">
            <img src="https://images.unsplash.com/photo-1549144510-18e38ee05b95?auto=format&fit=crop&w=600&q=80" alt="Edinburgh" loading="lazy" />
            <div class="travel-location">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--color-accent)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path><circle cx="12" cy="10" r="3"></circle></svg>
              Edinburgh, Scotland
            </div>
          </div>
        </div>

        <!-- Travel Card 4 -->
        <div class="travel-card glass">
          <div class="card-inner">
            <img src="https://images.unsplash.com/photo-1552832230-c0197dd311b5?auto=format&fit=crop&w=600&q=80" alt="Rome" loading="lazy" />
            <div class="travel-location">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--color-accent)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path><circle cx="12" cy="10" r="3"></circle></svg>
              Rome, Italy
            </div>
          </div>
        </div>
        
        <!-- Travel Card 5 -->
        <div class="travel-card glass">
          <div class="card-inner">
            <img src="https://images.unsplash.com/photo-1499856871958-5b9627545d1a?auto=format&fit=crop&w=600&q=80" alt="Paris" loading="lazy" />
            <div class="travel-location">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--color-accent)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path><circle cx="12" cy="10" r="3"></circle></svg>
              Paris, France
            </div>
          </div>
        </div>

        <!-- Travel Card 6 -->
        <div class="travel-card glass">
          <div class="card-inner">
            <img src="https://images.unsplash.com/photo-1560969184-10fe8719e047?auto=format&fit=crop&w=600&q=80" alt="Berlin" loading="lazy" />
            <div class="travel-location">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--color-accent)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path><circle cx="12" cy="10" r="3"></circle></svg>
              Heidelberg, Germany
            </div>
          </div>
        </div>
      </div>
    </div>

  </div>
</section>

<style>
  .about-section {
    position: relative;
    overflow: hidden; /* Contains the giant background text */
    padding-top: 110px; /* Reduced from 160px to push titles higher */
    padding-bottom: 2rem;
  }

  .relative-z {
    position: relative;
    z-index: 10;
  }

  /* Decorative Background Setup */
  .bg-typography {
    position: absolute;
    top: 50px;
    left: 50%;
    transform: translateX(-50%);
    font-size: 15vw;
    font-family: var(--font-sans);
    font-weight: 800;
    color: transparent;
    -webkit-text-stroke: 1px rgba(255, 255, 255, 0.03);
    white-space: nowrap;
    z-index: 1;
    pointer-events: none;
    letter-spacing: 0.1em;
  }

  .bg-orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
    z-index: 1;
    pointer-events: none;
    opacity: 0.2;
  }

  .orb-1 {
    width: 300px;
    height: 300px;
    background: var(--color-accent);
    top: 20%;
    left: -100px;
  }

  .orb-2 {
    width: 400px;
    height: 400px;
    background: var(--color-accent-secondary); /* Nebula Purple */
    bottom: 0;
    right: -100px;
  }

  /* Layout adjustments */
  .about-top-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
    margin-bottom: 3rem;
  }

  .about-header {
    text-align: left;
  }
  
  .subtitle {
    font-family: var(--font-mono);
    color: var(--color-text-muted);
    font-size: 1.1rem;
    margin-top: 1rem;
    line-height: 1.5;
  }

  .about-narrative-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    margin-bottom: 4rem;
  }

  .narrative-panel {
    padding: 2.5rem;
    border-radius: 12px;
    transition: transform 0.3s ease;
  }

  .narrative-panel:hover {
    transform: translateY(-5px);
  }

  .narrative-panel h3 {
    color: var(--color-accent);
    font-size: 1.4rem;
    margin-bottom: 1rem;
  }

  .narrative-panel p {
    font-size: 1.05rem;
    line-height: 1.7;
    color: var(--color-text-muted);
  }

  .highlight-border {
    border-top: 3px solid var(--color-accent);
    border-left: none;
  }

  /* Code Window Styling */
  .code-window {
    border-radius: 12px;
    overflow: hidden;
    background: var(--surface-gradient), rgba(10, 15, 28, 0.7);
    border: var(--surface-border);
    box-shadow: var(--surface-shadow);
    transition: transform 0.3s ease, border-color 0.3s ease, box-shadow 0.3s ease;
  }

  .code-window:hover {
    transform: translateY(-5px);
    box-shadow: 0 15px 40px rgba(0, 229, 255, 0.15);
    border-color: rgba(0, 229, 255, 0.4);
  }

  .code-header {
    display: flex;
    align-items: center;
    padding: 0.8rem 1rem;
    background: rgba(255, 255, 255, 0.03);
    border-bottom: var(--surface-border);
  }

  .dots {
    display: flex;
    gap: 6px;
  }

  .dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
  }

  .dot.red { background: #ff5f56; }
  .dot.yellow { background: #ffbd2e; }
  .dot.green { background: #27c93f; }

  .file-name {
    margin-left: 15px;
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--color-text-muted);
  }

  .code-window pre {
    margin: 0;
    padding: 1.5rem;
    font-family: var(--font-mono);
    font-size: 0.95rem;
    line-height: 1.6;
    overflow-x: auto;
  }

  .code-window code {
    color: var(--color-text);
  }

  .keyword { color: #c678dd; } /* Purple */
  .entity { color: #e5c07b; } /* Yellow */
  .function { color: #61afef; } /* Blue */
  .variable { color: #e06c75; } /* Red */
  .string { color: #98c379; } /* Green */
  .constant { color: #d19a66; } /* Orange */

  .about-skills-row {
    margin-top: 2rem;
  }

  .skills-inline-title {
    font-family: var(--font-mono);
    color: var(--color-accent);
    font-size: 1.4rem;
    letter-spacing: 0.1em;
    margin-bottom: 2rem;
    text-align: center;
  }

  .skills-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 1.5rem;
  }

  .skill-category {
    padding: 2rem;
    border-radius: 12px;
    background: var(--surface-gradient), rgba(10, 15, 28, 0.6);
    border: var(--surface-border);
    transition: transform 0.3s ease, border-color 0.3s ease, box-shadow 0.3s ease;
  }

  .skill-category:hover {
    transform: translateY(-5px);
    border-color: rgba(0, 229, 255, 0.4);
    box-shadow: 0 10px 30px rgba(0, 229, 255, 0.15);
  }

  .category-header {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1.5rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    padding-bottom: 1rem;
  }

  .category-icon {
    width: 28px;
    height: 28px;
  }

  .category-header h4 {
    font-family: var(--font-mono);
    font-size: 1.1rem;
    color: var(--color-text);
    margin: 0;
  }

  .skill-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
  }

  .tag {
    background-color: transparent;
    color: var(--color-text-muted);
    border: 1px solid rgba(255, 255, 255, 0.2);
    padding: 0.4rem 0.8rem;
    border-radius: 5px;
    font-size: 0.85rem;
    font-family: var(--font-mono);
    transition: all 0.3s ease;
  }

  .tag:hover {
    background-color: rgba(0, 229, 255, 0.1);
    color: var(--color-accent);
    border-color: var(--color-accent);
    box-shadow: 0 0 10px rgba(0, 229, 255, 0.2);
  }

  /* Travels & Exploration Section */
  .explorer-section {
    margin-top: 8rem;
  }

  .explorer-header {
    margin-top: 8rem;
    margin-bottom: 5rem;
    text-align: center;
  }
  
  .explorer-title {
    font-size: 2rem;
    font-family: var(--font-mono);
    margin-bottom: 1.5rem; 
  }

  .title-divider {
    width: 60px;
    height: 3px;
    background: var(--color-accent);
    margin: 0 auto 1.5rem auto;
    border-radius: 2px;
  }

  .explorer-subtitle {
    font-family: var(--font-mono);
    color: var(--color-text-muted);
    font-size: 1.1rem;
    margin-top: 0; /* Reset margin that globally conflicted */
  }

  .travel-gallery {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2.5rem;
  }

  .travel-card {
    border-radius: 12px;
    padding: 0.8rem;
    transition: transform 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275), box-shadow 0.5s ease;
    cursor: pointer;
    background: rgba(255, 255, 255, 0.02); /* More transparent for polaroid effect */
  }

  .travel-card:hover {
    transform: translateY(-15px) scale(1.05) rotate(2deg);
    border-color: var(--color-accent);
    box-shadow: 0 15px 30px rgba(0, 229, 255, 0.2);
    z-index: 2;
  }

  .travel-card:nth-child(even):hover {
    transform: translateY(-15px) scale(1.05) rotate(-2deg);
  }

  .card-inner {
    position: relative;
    border-radius: 8px;
    overflow: hidden;
    background: #000;
    box-shadow: inset 0 0 20px rgba(0,0,0,0.5);
  }

  .card-inner img {
    width: 100%;
    aspect-ratio: 4/5;
    object-fit: cover;
    opacity: 0.7;
    transition: opacity 0.5s ease, transform 0.5s ease;
    filter: sepia(20%) hue-rotate(-10deg) saturate(120%); /* Slight vintage sci-fi filter */
  }

  .travel-card:hover .card-inner img {
    opacity: 1;
    transform: scale(1.1);
    filter: grayscale(0%) sepia(0%) hue-rotate(0deg) saturate(100%);
  }

  .travel-location {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    padding: 1.5rem 1rem 1rem;
    background: linear-gradient(to top, rgba(0,0,0,0.9), transparent);
    font-family: var(--font-mono);
    font-size: 0.9rem;
    display: flex;
    align-items: center;
    gap: 0.6rem;
    transform: translateY(20px);
    opacity: 0;
    transition: all 0.3s ease;
  }

  .travel-card:hover .travel-location {
    transform: translateY(0);
    opacity: 1;
  }

  @media (max-width: 1024px) {
    .about-top-row, .about-narrative-row {
      grid-template-columns: 1fr;
    }
    .about-header {
      text-align: center;
      margin-bottom: 2rem;
    }
    .bg-typography {
      font-size: 25vw;
      top: 100px;
    }
    .highlight-border {
      border-left: 3px solid var(--color-accent);
      border-top: none;
    }
  }

  @media (max-width: 900px) {
    .travel-gallery {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 600px) {
    .travel-gallery {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }
    .travel-card:hover, .travel-card:nth-child(even):hover {
      transform: translateY(-5px) scale(1.02); /* Reduced movement on mobile */
    }
  }
</style>
