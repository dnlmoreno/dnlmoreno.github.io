<style>
  .about-section {
    position: relative;
    overflow: hidden; /* Contains the giant background text */
    padding-top: 110px; /* Reduced from 160px to push titles higher */
    padding-bottom: 2rem;
  }

  .relative-z {
    position: relative;
    z-index: 10;
  }

  /* Decorative Background Setup */
  .bg-typography {
    position: absolute;
    top: 50px;
    left: 50%;
    transform: translateX(-50%);
    font-size: 15vw;
    font-family: var(--font-sans);
    font-weight: 800;
    color: transparent;
    -webkit-text-stroke: 1px rgba(255, 255, 255, 0.03);
    white-space: nowrap;
    z-index: 1;
    pointer-events: none;
    letter-spacing: 0.1em;
  }

  .bg-orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
    z-index: 1;
    pointer-events: none;
    opacity: 0.2;
  }

  .orb-1 {
    width: 300px;
    height: 300px;
    background: var(--color-accent);
    top: 20%;
    left: -100px;
  }

  .orb-2 {
    width: 400px;
    height: 400px;
    background: var(--color-accent-secondary); /* Nebula Purple */
    bottom: 0;
    right: -100px;
  }

  /* Layout adjustments */
  .about-top-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
    margin-bottom: 3rem;
  }

  .about-header {
    text-align: left;
  }

  .subtitle {
    font-family: var(--font-mono);
    color: var(--color-text-muted);
    font-size: 1.4rem;
    margin-top: 1rem;
    line-height: 1.5;
  }

  .about-narrative-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    margin-bottom: 4rem;
  }

  .narrative-panel {
    padding: 2.5rem;
    border-radius: 12px;
    transition: transform 0.3s ease;
  }

  .narrative-panel:hover {
    transform: translateY(-5px);
  }

  .narrative-panel h3 {
    color: var(--color-accent);
    font-size: 1.4rem;
    margin-bottom: 1rem;
  }

  .narrative-panel p {
    font-size: 1.1rem;
    line-height: 1.7;
    color: var(--color-text-muted);
  }

  .highlight-border {
    border-top: 3px solid var(--color-accent);
    border-left: none;
  }

  /* Teaching Section Styling */
  .teaching-row {
    margin-bottom: 5rem;
  }

  .teaching-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1.5rem;
  }

  .teaching-card {
    position: relative;
    padding: 2.2rem 1.8rem 1.8rem;
    border-radius: 12px;
    border: var(--surface-border);
    transition: all 0.3s ease;
    overflow: hidden;
  }

  .teaching-card:hover {
    transform: translateY(-5px);
    border-color: var(--color-accent);
    box-shadow: 0 10px 30px rgba(0, 229, 255, 0.1);
  }

  .teaching-badge {
    position: absolute;
    top: 0;
    right: 0;
    background: rgba(0, 229, 255, 0.1);
    color: var(--color-accent);
    font-family: var(--font-mono);
    font-size: 0.7rem;
    padding: 0.3rem 0.8rem;
    border-bottom-left-radius: 10px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    border-left: 1px solid rgba(0, 229, 255, 0.2);
    border-bottom: 1px solid rgba(0, 229, 255, 0.2);
  }

  .teaching-badge.special {
    background: rgba(157, 78, 221, 0.1); /* Nebula Purple */
    color: var(--color-accent-secondary);
    border-color: rgba(157, 78, 221, 0.2);
  }

  .teaching-badge.blue {
    background: rgba(0, 203, 226, 0.1);
    color: var(--color-accent);
    border-color: rgba(0, 203, 226, 0.2);
  }

  .highlight-card-purple {
    border-left: 3px solid var(--color-accent-secondary);
  }

  .highlight-card-blue {
    border-left: 3px solid var(--color-accent);
  }

  .teaching-institution {
    display: block;
    font-size: 0.95rem;
    font-weight: 600;
    font-family: var(--font-mono);
    color: var(--color-accent);
    opacity: 0.9;
    margin-top: 0.5rem;
    margin-bottom: 0.4rem;
  }

  .teaching-year {
    font-size: 0.85rem;
    font-weight: 400;
    opacity: 0.6;
    margin-left: 0.3rem;
  }

  .teaching-content h4 {
    font-size: 1.15rem;
    color: var(--color-text);
    margin-bottom: 0.5rem;
  }

  .teaching-content p {
    font-size: 0.9rem;
    color: var(--color-text-muted);
    line-height: 1.5;
  }

  /* Code Window Styling */
  .code-window {
