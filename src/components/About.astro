---

---

<section id="about" class="section about-section">
  <!-- Decorative Background Typography -->
  <div class="bg-typography">ABOUT</div>
  <div class="bg-orb orb-1"></div>
  <div class="bg-orb orb-2"></div>

  <div class="container relative-z">
    <div class="about-top-row fade-in">
      <div class="about-header">
        <h2 class="section-title">
          The Mind Behind the <span class="text-accent">Models</span>
        </h2>
        <p class="subtitle">
          Exploring the cosmos through the lens of artificial intelligence.
        </p>
      </div>

      <!-- Code Terminal -->
      <div class="code-window glass">
        <div class="code-header">
          <div class="dots">
            <span class="dot red"></span>
            <span class="dot yellow"></span>
            <span class="dot green"></span>
          </div>
          <span class="file-name">perfil.py</span>
        </div>
        <pre><code><span class="keyword">class</span> <span class="entity">MLEngineerResearcher</span>:
    <span class="keyword">def</span> <span class="function">__init__</span>(<span class="variable">self</span>):
        <span class="variable">self</span>.role = <span class="string">"AI for Science, Society and Industry"</span>
        <span class="variable">self</span>.stack = [<span class="string">"ML"</span>, <span class="string">"Science"</span>, <span class="string">"Business"</span>]
        
    <span class="keyword">def</span> <span class="function">build_future</span>(<span class="variable">self</span>):
        <span class="keyword">while</span> <span class="constant">True</span>:
            <span class="keyword">yield</span> <span class="variable">self</span>.innovate()</code></pre>
      </div>
    </div>

    <!-- Row 2: Narrative Panels -->
    <div class="about-narrative-row fade-in">
      <div class="glass narrative-panel">
        <h3>My Journey</h3>
        <p>
          I earned my degree in <strong>Civil Industrial Engineering</strong> and
          later a <strong>Master's in Computer Science</strong> from the Universidad
          de Concepción. During my master's, I completed two pivotal 3-4 month research
          internships at <strong>Harvard University</strong> in Boston, focusing on
          the implementation of AI models in astronomy. This experience yielded several
          publications in prominent journals and top-tier conference workshops, further
          solidifying my commitment to scientific discovery and honing my technical
          expertise.
        </p>
      </div>

      <div class="glass narrative-panel highlight-border">
        <h3>Current Focus & Vision</h3>
        <p>
          Currently, I deploy AI for real-world scientific discovery as an ML
          Engineer at
          <a
            href="https://science.alerce.online"
            target="_blank"
            rel="noopener noreferrer"
            style="color: inherit; text-decoration: underline;"
          >
            <strong>ALeRCE</strong>
          </a>, while continuously expanding my horizons. I am actively learning
          more about the startup ecosystem, large-scale generative AI
          applications, and agentic automation.
        </p>
        <p style="margin-top: 1rem;">
          My ultimate goal is to design robust and reliable AI systems that
          contribute to science and society, while mentoring the next generation
          of researchers from the Global South. I am always open to contributing
          to high-impact research, open-source technology, and collaborative
          projects.
        </p>
      </div>
    </div>

    <!-- Row: Teaching & Academic Impact -->
    <div class="teaching-row fade-in">
      <h3 class="skills-inline-title">Lectures & Mentorship</h3>
      <div class="teaching-grid">
        <!-- UdeC Courses -->
        <div class="teaching-card glass highlight-card-blue">
          <div class="teaching-badge">Master in Computer Science</div>
          <div class="teaching-content">
            <span class="teaching-institution">Universidad de Concepción</span>
            <h4>Deep Learning</h4>
            <p>
              Theory and applications of neural architectures, autoencoders, and
              transformers.
            </p>
          </div>
        </div>
        <div class="teaching-card glass highlight-card-blue">
          <div class="teaching-badge">Master in Computer Science</div>
          <div class="teaching-content">
            <span class="teaching-institution">Universidad de Concepción</span>
            <h4>Data Science</h4>
            <p>
              Probability, statistics, and deep dive into predictive machine
              learning methods.
            </p>
          </div>
        </div>
        <div class="teaching-card glass highlight-card-blue">
          <div class="teaching-badge">Diploma in Artificial Intelligence</div>
          <div class="teaching-content">
            <span class="teaching-institution">Universidad de Concepción</span>
            <h4>Machine Learning</h4>
            <p>
              Classical supervised, unsupervised, and reinforcement learning
              strategies.
            </p>
          </div>
        </div>
        <div class="teaching-card glass highlight-card-blue">
          <div class="teaching-badge">
            Master in Data Science for Innovation
          </div>
          <div class="teaching-content">
            <span class="teaching-institution">Universidad de Concepción</span>
            <h4>Data Analytics</h4>
            <p>
              Web scraping and stats for transforming raw data into business
              knowledge.
            </p>
          </div>
        </div>

        <!-- Workshops / Professional Training -->
        <div class="teaching-card glass highlight-card-purple">
          <div class="teaching-badge special">
            MACI International Internship
          </div>
          <div class="teaching-content">
            <span class="teaching-institution">Harvard University</span>
            <h4>Machine Learning</h4>
            <p>
              Week-long training sessions on Python and classical ML for
              visiting students from the Master in Data Science for Innovation
              program.
            </p>
          </div>
        </div>
        <div class="teaching-card glass highlight-card-purple">
          <div class="teaching-badge special">Specialized Training</div>
          <div class="teaching-content">
            <span class="teaching-institution">Minera Collahuasi</span>
            <h4>ML for Engineers</h4>
            <p>
              Data extraction and analysis training for mining industry
              engineers.
            </p>
          </div>
        </div>
      </div>
    </div>

    <!-- Arsenal Inside Main Block -->
    <div class="about-skills-row fade-in">
      <h3 class="skills-inline-title">Arsenal & Tech Stack</h3>

      <div class="skills-grid">
        <!-- Category 1 -->
        <div class="skill-category glass">
          <div class="category-header">
            <svg
              class="category-icon"
              viewBox="0 0 24 24"
              fill="none"
              stroke="var(--color-accent)"
              stroke-width="1.5"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path
                d="M12 5a3 3 0 1 0-5.997.125 4 4 0 0 0-2.526 5.77 4 4 0 0 0 .52 5.586 3.004 3.004 0 0 0 5.193 2.019A15.822 15.822 0 0 0 12 20a15.822 15.822 0 0 0 2.81-1.5 3.004 3.004 0 0 0 5.193-2.019 4 4 0 0 0 .52-5.586 4 4 0 0 0-2.526-5.77A3 3 0 1 0 12 5Z"
              ></path>
            </svg>
            <h4>Deep Learning & AI</h4>
          </div>
          <div class="skill-tags">
            <span class="tag">PyTorch</span>
            <span class="tag">TensorFlow</span>
            <span class="tag">Hugging Face</span>
            <span class="tag">OpenAI</span>
            <span class="tag">Anthropic</span>
