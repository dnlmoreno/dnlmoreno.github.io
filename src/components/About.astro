                d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5"></path></svg
            >
            <h4>Data Engineering</h4>
          </div>
          <div class="skill-tags">
            <span class="tag">SQL / BigQuery</span>
            <span class="tag">Apache Spark</span>
            <span class="tag">Kafka</span>
            <span class="tag">Airflow</span>
            <span class="tag">dbt</span>
          </div>
        </div>

        <!-- Category 4 -->
        <div class="skill-category glass">
          <div class="category-header">
            <svg
              class="category-icon"
              viewBox="0 0 24 24"
              fill="none"
              stroke="var(--color-accent)"
              stroke-width="1.5"
              stroke-linecap="round"
              stroke-linejoin="round"
              ><rect x="2" y="2" width="20" height="8" rx="2" ry="2"
              ></rect><rect x="2" y="14" width="20" height="8" rx="2" ry="2"
              ></rect><line x1="6" y1="6" x2="6.01" y2="6"></line><line
                x1="6"
                y1="18"
                x2="6.01"
                y2="18"></line></svg
