---
---
<section id="contact" class="section contact-section">
  <!-- Decorative Abstract Typography -->
  <div class="bg-typography right relative-z">CONTACT</div>
  <div class="bg-orb orb-1"></div>
  
  <div class="container contact-container relative-z z-10">
    <div class="about-header text-center fade-in">
      <h2 class="section-title">Let's <span class="text-accent">Talk</span></h2>
      <p class="subtitle">Looking for collaborations, speaking engagements, or deep learning consulting.</p>
    </div>
    
    <div class="contact-split">
      
      <!-- Terminal Motif UI -->
      <div class="terminal-ui glass fade-in">
        <div class="terminal-header">
          <div class="t-btn red"></div>
          <div class="t-btn yellow"></div>
          <div class="t-btn green"></div>
          <span class="t-title">guest@portfolio: ~/contact</span>
        </div>
        
        <div class="terminal-body" id="term-body">
          <p><span class="prompt">guest@portfolio:~$</span> ./init_connection.sh --target "Daniel"</p>
          <p class="sys-msg">[INFO] Establishing secure quantum connection...</p>
          <p class="sys-msg delay-1">[SUCCESS] Connected to server.</p>
          <p class="sys-msg delay-1">[INFO] Checking availability...</p>
          <p class="sys-msg delay-2 text-accent">STATUS: Online. Ready for transmission.</p>
          <p class="delay-2"><span class="prompt">guest@portfolio:~$</span> echo "Send me a direct message." <span class="term-cursor">_</span></p>
        </div>
        
        <div class="contact-methods delay-3">
          <h4 class="mono-title">// Direct Protocols //</h4>
          <a href="mailto:damoreno.cartagena@gmail.com" class="method-link">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg>
            damoreno.cartagena@gmail.com
          </a>
          <!-- Added other links previously requested by user to be clean -->
          <a href="https://linkedin.com/in/danielmorenoc" target="_blank" class="method-link">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"></path><rect x="2" y="9" width="4" height="12"></rect><circle cx="4" cy="4" r="2"></circle></svg>
            LinkedIn
          </a>
        </div>
      </div>

      <!-- Contact Form -->
      <div class="contact-form-wrapper glass fade-in relative-z">
        <!-- Replaced [TU_ID] with standard action -->
        <form action="https://formspree.io/f/[TU_ID]" method="POST" class="contact-form">
          <div class="form-group">
            <label for="name">Name</label>
            <input type="text" id="name" name="name" required placeholder="John Doe" />
          </div>
          
          <div class="form-group">
            <label for="email">Email</label>
            <input type="email" id="email" name="email" required placeholder="john@example.com" />
          </div>
          
          <div class="form-group">
            <label for="subject">Subject</label>
            <input type="text" id="subject" name="subject" required placeholder="Let's collaborate!" />
          </div>
          
          <div class="form-group">
            <label for="message">Message</label>
            <!-- No hardcoded green styling to maintain purity, handled in css -->
            <textarea id="message" name="message" rows="5" required placeholder="Hi Daniel, I loved your paper on..."></textarea>
          </div>
          
          <button type="submit" class="btn btn-primary submit-btn">
            Send Message
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="22" y1="2" x2="11" y2="13"></line><polygon points="22 2 15 22 11 13 2 9 22 2"></polygon></svg>
          </button>
        </form>
      </div>

    </div>
  </div>
</section>

<style>
  .contact-section {
    position: relative;
    height: 100%;
    min-height: 80vh;
    display: flex;
    flex-direction: column;
    justify-content: flex-start; /* Push everything firmly to the top */
    padding-top: 20px; /* Securely clear the navbar */
    padding-bottom: 20px;
    overflow: hidden; /* Strict fit */
  }

  .contact-container {
    height: 100%;
    display: flex;
    flex-direction: column;
    justify-content: flex-start; /* Start from the top immediately after padding */
  }

  .relative-z { position: relative; }
  .z-10 { z-index: 10; }

  .bg-orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
    z-index: 1;
    pointer-events: none;
    opacity: 0.15;
  }

  .orb-1 {
    width: 350px;
    height: 350px;
    background: #0088ff;
    top: 50%;
    left: -150px;
  }

  .bg-typography {
    position: absolute;
    top: 50px;
    right: -10vw;
    font-size: 15vw;
    font-family: var(--font-sans);
    font-weight: 800;
    color: transparent;
    -webkit-text-stroke: 1px rgba(255, 255, 255, 0.03);
    white-space: nowrap;
    z-index: 1;
    pointer-events: none;
    letter-spacing: 0.1em;
  }

  .about-header {
    margin-bottom: 2rem; /* Reduced from 4rem */
  }
  
  .subtitle {
    font-family: var(--font-mono);
    color: var(--color-text-muted);
    font-size: 1rem;
    margin-top: -1rem;
  }

  .contact-split {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem; /* Reduced from 3rem */
  }

  /* Terminal UI */
  .terminal-ui {
    border-radius: 12px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    border: var(--surface-border);
    box-shadow: var(--surface-shadow);
  }

  .terminal-header {
    background: rgba(0, 0, 0, 0.4);
    padding: 0.8rem 1rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    border-bottom: 1px solid rgba(255,255,255,0.05);
  }

  .t-btn {
    width: 12px;
    height: 12px;
    border-radius: 50%;
  }

  .t-btn.red { background: #ff5f56; }
  .t-btn.yellow { background: #ffbd2e; }
  .t-btn.green { background: #27c93f; }

  .t-title {
    margin-left: auto;
    margin-right: auto;
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--color-text-muted);
  }

  .terminal-body {
    padding: 1rem 1.5rem; /* Reduced padding */
    font-family: var(--font-mono);
    font-size: 0.85rem; /* Reduced font size */
    color: var(--color-text);
    line-height: 1.6;
  }

  .prompt {
    color: var(--color-accent);
  }

  .sys-msg {
    color: var(--color-text-muted);
  }

  .term-cursor {
    display: inline-block;
    width: 10px;
    height: 1.2em;
    background: var(--color-accent);
    vertical-align: middle;
    animation: blink 1s step-end infinite;
  }

  @keyframes blink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0; }
  }

  /* Animations for Terminal Load */
  .delay-1 { animation: showLine 2s steps(1, end) forwards; opacity: 0; }
  .delay-2 { animation: showLine 3s steps(1, end) forwards; opacity: 0; }
  .delay-3 { animation: fadeLine 4s ease forwards; opacity: 0; }

  @keyframes showLine { to { opacity: 1; } }
  @keyframes fadeLine { to { opacity: 1; } }

  .contact-methods {
    padding: 0 1.5rem 1.5rem 1.5rem;
    margin-top: auto;
  }

  .mono-title {
    font-family: var(--font-mono);
    color: var(--color-text-muted);
    font-size: 0.8rem;
    margin-bottom: 0.6rem;
  }

  .method-link {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.6rem;
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(255,255,255,0.05);
    border-radius: 8px;
    margin-bottom: 0.6rem;
    font-family: var(--font-mono);
    font-size: 0.8rem;
    transition: all 0.3s ease;
  }

  .method-link:hover {
    border-color: var(--color-accent);
    background: rgba(0, 229, 255, 0.05);
    color: var(--color-accent);
    transform: translateX(5px);
  }

  /* Contact Form Wrapper */
  .contact-form-wrapper {
    padding: 1.5rem 2rem; /* Reduced from 3rem */
    border-radius: 12px;
    border: var(--surface-border);
    box-shadow: var(--surface-shadow);
  }

  .form-group {
    margin-bottom: 0.8rem; /* Reduced from 1.5rem */
  }

  .form-group label {
    display: block;
    font-size: 0.85rem;
    font-family: var(--font-mono);
    color: var(--color-text-muted);
    margin-bottom: 0.3rem; /* Reduced */
  }

  .form-group input,
  .form-group textarea {
    width: 100%;
    padding: 0.6rem 1rem; /* Reduced from 1rem */
    background: rgba(255, 255, 255, 0.02);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 8px;
    color: var(--color-text);
    font-family: var(--font-sans);
    font-size: 0.9rem;
    transition: all 0.3s ease;
  }

  .form-group input:focus,
  .form-group textarea:focus {
    outline: none;
    border-color: var(--color-accent);
    background: rgba(0, 229, 255, 0.02);
    box-shadow: 0 0 10px rgba(0, 229, 255, 0.1);
  }

  .submit-btn {
    width: 100%;
    padding: 0.8rem; /* Reduced from 1rem */
    font-size: 1rem;
  }

  @media (max-width: 900px) {
    .contact-split {
      grid-template-columns: 1fr;
    }
    
    .contact-form-wrapper {
      padding: 2rem;
    }
  }
</style>
