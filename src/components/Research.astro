---
import { papersBloqueA, contributionsBloqueB } from "../data/research.js";

// Helper to get badge class based on venue
const getBadgeClass = (venue: string) => {
  if (venue.includes("ICML")) return "badge-yellow";
  if (venue.includes("Thesis")) return "badge-green";
  if (venue.includes("LARIM")) return "badge-yellow";
  return "badge-blue"; // Default Journals
};
---

<section id="research" class="section research-section">
  <!-- Decorative Abstract Typography & Orbs -->
  <div class="bg-typography right relative-z">RESEARCH</div>
  <div class="bg-orb orb-1"></div>

  <div class="container relative-z z-10">
    <div class="research-header fade-in">
      <h2 class="section-title">
        Research & <span class="text-accent">Publications</span>
      </h2>
      <div class="mock-filters">
        <button class="filter-btn active" data-filter="all">All</button>
        <button class="filter-btn" data-filter="transformers"
          >Transformers</button
        >
        <button class="filter-btn" data-filter="time series">Time Series</button
        >
        <button class="filter-btn" data-filter="astrophysics"
          >Astrophysics</button
        >
      </div>
    </div>

    <!-- Bloque A: First Author Papers -->
    <div class="research-block fade-in">
      <h3 class="subsection-title">First Author Papers</h3>

      <div class="papers-grid">
        {
          papersBloqueA.map((paper) => (
            <article
              class="paper-card glass"
              data-keywords={[...paper.data, ...paper.frameworks]
                .join(" ")
                .toLowerCase()}
            >
              <div class="paper-image-wrapper">
                <img
                  src={paper.image.replace("3b82f6", "00e5ff")}
                  alt={paper.title}
                  class="paper-image"
                  loading="lazy"
                />

                <div class="status-badge-container">
                  {paper.status === "published" ? (
                    <span class="status-badge published">Published</span>
                  ) : (
                    <span class="status-badge in-progress">In Progress</span>
                  )}
                </div>
              </div>

              <div class="paper-content">
                <span class={`venue-badge ${getBadgeClass(paper.venue)}`}>
                  {paper.venue}
                </span>
                <h4 class="paper-title">{paper.title}</h4>
                <p class="paper-desc">{paper.description}</p>

                <div class="paper-chips">
                  {paper.data.map((d) => (
                    <span class="chip chip-data">{d}</span>
                  ))}
                  {paper.frameworks.map((f) => (
                    <span class="chip chip-framework">{f}</span>
                  ))}
                </div>

                <div class="paper-actions">
                  {paper.paper ? (
                    <a
                      href={paper.paper}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="btn btn-primary btn-sm"
                    >
                      Read Paper
                    </a>
                  ) : (
                    <button
                      class="btn btn-primary btn-sm"
                      disabled
                      title="Coming soon"
                    >
                      Read Paper
                    </button>
                  )}

                  {paper.github ? (
                    <a
                      href={paper.github}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="btn btn-sm"
                    >
                      <svg
                        width="18"
                        height="18"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                      >
                        <path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22" />
                      </svg>
                      GitHub
                    </a>
                  ) : (
                    <button class="btn btn-sm tooltip-trigger" disabled>
                      <svg
                        width="18"
                        height="18"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                      >
                        <path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22" />
                      </svg>
                      GitHub
                      <span class="tooltip">Coming soon</span>
                    </button>
                  )}
                </div>
              </div>
            </article>
          ))
        }
      </div>
    </div>

    <!-- Bloque B: Contributions -->
    <div class="research-block contributions-block fade-in">
      <h3 class="subsection-title">Contributions & Co-Authored Papers</h3>

      <div class="contributions-list">
        {
          contributionsBloqueB.map((contrib) => (
            <div
              class="contribution-item glass"
              data-keywords={contrib.frameworks.join(" ").toLowerCase()}
            >
              <span class={`venue-badge ${getBadgeClass(contrib.venue)}`}>
                {contrib.venue}
              </span>
              <h4 class="contrib-title" title={contrib.title}>
                {contrib.title}
              </h4>
              <div class="paper-chips inline">
                {contrib.frameworks.map((f) => (
                  <span class="chip chip-framework">{f}</span>
                ))}
              </div>

              <div class="contrib-actions">
                {contrib.paper && (
                  <a
                    href={contrib.paper}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="link-btn"
                    title="Read Paper"
                  >
                    <svg
                      width="20"
                      height="20"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                    >
                      <path d="M14 2H6a2 2 0 0 0-2 2v16c0 1.1.9 2 2 2h12a2 2 0 0 0 2-2V8l-6-6z" />
                      <path d="M14 3v5h5M16 13H8M16 17H8M10 9H8" />
                    </svg>
                  </a>
                )}
                {contrib.github && (
                  <a
                    href={contrib.github}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="link-btn"
                    title="GitHub Repo"
                  >
                    <svg
                      width="20"
                      height="20"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                    >
                      <path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22" />
                    </svg>
                  </a>
                )}
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>

<style>
  .research-section {
    position: relative;
    padding-top: 110px; /* Reduced to push items higher */
    padding-bottom: 2rem;
    overflow: hidden;
  }

  .relative-z {
    position: relative;
  }
  .z-10 {
    z-index: 10;
  }

  /* Decorative Background Setup */
  .bg-typography {
    position: absolute;
    top: 50px;
    right: -10vw;
    font-size: 15vw;
    font-family: var(--font-sans);
    font-weight: 800;
    color: transparent;
    -webkit-text-stroke: 1px rgba(255, 255, 255, 0.03);
    white-space: nowrap;
    z-index: 1;
    pointer-events: none;
    letter-spacing: 0.1em;
  }

  .bg-orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
    z-index: 1;
    pointer-events: none;
    opacity: 0.15;
  }

  .orb-1 {
    width: 350px;
    height: 350px;
    background: var(--color-accent);
    top: 0;
    left: -150px;
  }

  .research-block {
    margin-bottom: 5rem;
  }

  .subsection-title {
    font-size: 1.8rem;
    margin-bottom: 2rem;
    border-left: 4px solid var(--color-accent);
    padding-left: 1rem;
  }

  /* Mock Filters */
  .research-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    margin-bottom: 3rem;
    flex-wrap: wrap;
    gap: 1.5rem;
  }

  .research-header .section-title {
    margin-bottom: 0;
  }

  .mock-filters {
    display: flex;
    gap: 0.8rem;
    background: var(--surface-gradient), rgba(10, 15, 28, 0.6);
    padding: 0.5rem;
    border-radius: 50px;
    border: var(--surface-border);
  }

  .filter-btn {
    background: transparent;
    color: var(--color-text-muted);
    border: none;
    padding: 0.5rem 1rem;
    border-radius: 50px;
    font-family: var(--font-mono);
    font-size: 0.8rem;
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .filter-btn:hover {
    color: var(--color-text);
  }

  .filter-btn.active {
    background: var(--color-accent);
    color: var(--color-bg);
  }

  /* Grid Bloque A */
  .papers-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.5rem;
  }

  .paper-card {
    border-radius: 12px;
    overflow: hidden;
    border: var(--surface-border);
    display: flex;
    flex-direction: column;
    transition:
      transform 0.3s ease,
      border-color 0.3s ease,
      box-shadow 0.3s ease;
  }

  .paper-card:hover {
    transform: translateY(-8px);
    border-color: rgba(0, 229, 255, 0.4);
    box-shadow: 0 15px 40px rgba(0, 0, 0, 0.8);
  }

  .paper-image-wrapper {
    position: relative;
    width: 100%;
    height: 160px; /* Reduced slightly to fit 4 cols better */
    overflow: hidden;
    background-color: var(--color-bg);
  }

  .paper-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition:
      transform 0.8s ease,
      filter 0.5s ease;
  }

  .paper-card:hover .paper-image {
    transform: scale(1.1);
    filter: brightness(0.6) sepia(100%) hue-rotate(90deg) saturate(300%);
  }

  .status-badge-container {
    position: absolute;
    top: 1rem;
    right: 1rem;
  }

  .status-badge {
    padding: 0.3rem 0.6rem;
    border-radius: 50px;
    font-size: 0.65rem;
    font-weight: bold;
    font-family: var(--font-mono);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .published {
    background-color: var(--color-accent);
    color: var(--color-bg);
  }

  .in-progress {
    background-color: transparent;
    color: var(--color-text);
    border: 1px dashed var(--color-text);
    animation: pulse 2s infinite;
  }

  @keyframes pulse {
    0% {
      opacity: 0.6;
    }
    50% {
      opacity: 1;
      border-color: var(--color-accent);
      color: var(--color-accent);
    }
    100% {
      opacity: 0.6;
    }
  }

  .paper-content {
    padding: 1.2rem;
    display: flex;
    flex-direction: column;
    flex: 1;
  }

  .venue-badge {
    align-self: flex-start;
    font-size: 0.7rem;
    padding: 0.2rem 0.5rem;
    border-radius: 4px;
    font-family: var(--font-mono);
    margin-bottom: 0.8rem;
  }

  .badge-yellow {
    background-color: rgba(255, 204, 0, 0.1);
    color: #ffcc00;
  }
  .badge-blue {
    background-color: rgba(0, 153, 255, 0.1);
    color: #0099ff;
  }
  .badge-green {
    background-color: rgba(0, 229, 255, 0.1);
    color: var(--color-accent);
  }

  .paper-title {
    font-size: 1.1rem;
    margin-bottom: 0.6rem;
    line-height: 1.3;
  }

  .paper-desc {
    font-size: 0.85rem;
    color: var(--color-text-muted);
    margin-bottom: 1.2rem;
    flex: 1;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .paper-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-bottom: 1.2rem;
  }

  .paper-chips.inline {
    margin-bottom: 0;
  }

  .chip {
    font-size: 0.7rem;
    padding: 0.2rem 0.5rem;
    border-radius: 4px;
    font-family: var(--font-mono);
  }

  .chip-data {
    background-color: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.1);
  }

  .chip-framework {
    background-color: rgba(0, 229, 255, 0.05);
    border: 1px solid rgba(0, 229, 255, 0.2);
    color: var(--color-accent);
  }

  .paper-actions {
    display: flex;
    gap: 0.8rem;
    margin-top: auto;
  }

  .btn-sm {
    padding: 0.4rem 0.8rem;
    font-size: 0.75rem;
    flex: 1;
  }

  /* Tooltip */
  .tooltip-trigger {
    position: relative;
  }

  .tooltip-trigger .tooltip {
    visibility: hidden;
    background-color: var(--color-surface);
    color: var(--color-text);
    text-align: center;
    border-radius: 4px;
    padding: 0.4rem 0.8rem;
    position: absolute;
    z-index: 1;
    bottom: 125%;
    left: 50%;
    margin-left: -50px;
    opacity: 0;
    transition: opacity 0.3s;
    font-size: 0.75rem;
    border: 1px solid var(--color-text-muted);
    white-space: nowrap;
  }

  .tooltip-trigger:hover .tooltip {
    visibility: visible;
    opacity: 1;
  }

  /* Bloque B Strict Alignment Using CSS Grid */
  .contributions-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .contribution-item {
    display: grid;
    /* Strict Column Alignment: Venue Badge -> Title -> Framework Chips -> Action Buttons */
    grid-template-columns: 120px 1fr auto 100px;
    gap: 2rem;
    align-items: center;
    padding: 1.2rem 1.5rem;
    border-radius: 8px;
    border: var(--surface-border);
    transition:
      border-color 0.3s ease,
      background-color 0.3s ease,
      box-shadow 0.3s ease;
  }

  .contribution-item:hover {
    border-color: rgba(0, 229, 255, 0.3);
    background-color: rgba(10, 10, 10, 0.9);
  }

  /* Force venue badge to look good inside its strict column */
  .contribution-item .venue-badge {
    margin-bottom: 0;
    text-align: center;
    justify-self: start;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    display: block;
    width: 100%;
  }

  .contrib-title {
    font-size: 1rem;
    font-family: var(--font-sans);
    font-weight: 500;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .contrib-actions {
    display: flex;
    gap: 1rem;
    justify-content: flex-end;
  }

  .link-btn {
    color: var(--color-text-muted);
    transition: color 0.3s ease;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .link-btn:hover {
    color: var(--color-accent);
  }

  @media (max-width: 1200px) {
    .papers-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
  @media (max-width: 900px) {
    .papers-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .contribution-item {
      /* Collapse chips if screen smaller */
      grid-template-columns: 100px 1fr 80px;
      gap: 1rem;
    }

    /* Hide chips on smaller screens inside block B */
    .contribution-item .paper-chips {
      display: none;
    }
  }
  @media (max-width: 600px) {
    .papers-grid {
      grid-template-columns: 1fr;
    }

    .contribution-item {
      display: flex;
      flex-direction: column;
      align-items: flex-start;
      gap: 0.8rem;
    }

    .contrib-actions {
      width: 100%;
      justify-content: flex-end;
      border-top: 1px solid rgba(255, 255, 255, 0.1);
      padding-top: 0.8rem;
    }
  }
</style>

<script>
  // --- Research keyword filter logic ---
  const initFilter = () => {
    const buttons = document.querySelectorAll<HTMLButtonElement>(".filter-btn");
    const paperCards = document.querySelectorAll<HTMLElement>(".paper-card");
    const contribItems =
      document.querySelectorAll<HTMLElement>(".contribution-item");

    // Map filter button label -> keywords to match against data-keywords
    const KEYWORD_MAP: Record<string, string[]> = {
      all: [],
      transformers: ["transformers", "vit", "astromer", "atat", "transformer"],
      "time series": [
        "time series",
        "light curves",
        "irregular time series",
        "alert streams",
      ],
      astrophysics: [
        "time series",
        "multi-band",
        "light curves",
        "irregular time series",
        "alert streams",
        "simulated data",
        "astromer",
        "atat",
      ],
    };

    const filterItems = (
      items: NodeListOf<HTMLElement>,
      keywords: string[],
    ) => {
      items.forEach((item) => {
        const kw = (item.dataset.keywords || "").toLowerCase();
        if (keywords.length === 0) {
          item.style.display = "";
          item.style.opacity = "1";
        } else {
          const matches = keywords.some((k) => kw.includes(k));
          item.style.display = matches ? "" : "none";
          item.style.opacity = matches ? "1" : "0";
        }
      });
    };

    buttons.forEach((btn) => {
      btn.addEventListener("click", () => {
        buttons.forEach((b) => b.classList.remove("active"));
        btn.classList.add("active");

        const filterKey = (btn.dataset.filter || "all").toLowerCase();
        const keywords = KEYWORD_MAP[filterKey] ?? [];

        filterItems(paperCards, keywords);
        filterItems(contribItems, keywords);
      });
    });
  };

  document.addEventListener("DOMContentLoaded", initFilter);
</script>
