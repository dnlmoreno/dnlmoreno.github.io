---
// Services.astro
---
<section id="services" class="section services-section">
  <!-- Decorative Background -->
  <div class="bg-typography">SERVICES</div>
  <div class="bg-orb orb-s1"></div>
  <div class="bg-orb orb-s2"></div>

  <div class="container relative-z">
    <!-- Header (no freelance badge here) -->
    <div class="services-header fade-in">
      <h2 class="section-title">What I Can Build <span class="text-accent">For You</span></h2>
      <p class="subtitle">
        From cutting-edge AI systems to polished web experiences — I bring research-grade rigor to real-world projects.
      </p>
    </div>

    <!-- Services Grid (3 cards) -->
    <div class="services-grid fade-in">

      <!-- Card 1: AI/ML Consulting (merged with Data Science) -->
      <div class="service-card glass">
        <div class="card-glow"></div>
        <div class="service-icon-wrap">
          <div class="service-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 2a10 10 0 1 0 10 10A10 10 0 0 0 12 2z"/>
              <path d="M12 8v4l3 3"/>
              <circle cx="12" cy="12" r="3" fill="var(--color-accent)" fill-opacity="0.15"/>
            </svg>
          </div>
        </div>
        <h3 class="service-title">AI & ML Consulting</h3>
        <p class="service-desc">Custom model design, architecture reviews, and research-to-production guidance.</p>
        <ul class="service-features">
          <li>Transform raw data into actionable insights for smarter decisions</li>
          <li>Bridging the gap between academia and industry applications</li>
          <li>End-to-end data pipelines</li>
        </ul>
        <div class="service-tag-row">
          <span class="stag">PyTorch</span>
          <span class="stag">Transformers</span>
          <span class="stag">Data Science</span>
          <span class="stag">MLOps</span>
        </div>
      </div>

      <!-- Card 2: AI Agents & RAG Systems -->
      <div class="service-card glass">
        <div class="card-glow"></div>
        <div class="service-icon-wrap">
          <div class="service-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
              <path d="M8 10h.01M12 10h.01M16 10h.01"/>
            </svg>
          </div>
        </div>
        <h3 class="service-title">AI Agents & RAG Systems</h3>
        <p class="service-desc">Custom LLM-powered agents, RAG pipelines, and intelligent chatbots that integrate seamlessly with your existing workflows and knowledge bases.</p>
        <ul class="service-features">
          <li>Custom RAG pipelines</li>
          <li>Intelligent chatbots</li>
          <li>Agentic automation</li>
        </ul>
        <div class="service-tag-row">
          <span class="stag">LangChain</span>
          <span class="stag">OpenAI</span>
          <span class="stag">Pinecone</span>
          <span class="stag">LlamaIndex</span>
        </div>
      </div>

      <!-- Card 3: Web Development (featured) -->
      <div class="service-card glass">
        <div class="card-glow"></div>
        <div class="service-icon-wrap">
          <div class="service-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <rect x="3" y="3" width="18" height="18" rx="2"/>
              <path d="M3 9h18M9 21V9"/>
            </svg>
          </div>
        </div>
        <h3 class="service-title">Web Development</h3>
        <p class="service-desc">Modern, high-performance websites and portfolios — from personal brand sites to full product pages, built with premium aesthetics and scalable architecture.</p>
        <ul class="service-features">
          <li>Portfolio & landing pages</li>
          <li>Product & startup sites</li>
          <li>Performance optimization</li>
        </ul>
        <div class="service-tag-row">
          <span class="stag">Astro</span>
          <span class="stag">Next.js</span>
          <span class="stag">React</span>
          <span class="stag">TypeScript</span>
        </div>
      </div>


    </div><!-- .services-grid -->

    <!-- CTA Row -->
    <div class="services-cta fade-in">
      <p class="cta-text">Have a project in mind? Let's make it happen.</p>
      <a href="#contact" class="btn btn-primary cta-btn">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg>
        Get in Touch
      </a>
    </div>

  </div>
</section>

<style>
  .services-section {
    position: relative;
    overflow: hidden;
    padding-top: 120px;
    padding-bottom: 80px;
  }

  .relative-z {
    position: relative;
    z-index: 10;
  }

  /* Decorative Background */
  .bg-typography {
    position: absolute;
    top: 60px;
    left: 50%;
    transform: translateX(-50%);
    font-size: 15vw;
    font-family: var(--font-sans);
    font-weight: 800;
    color: transparent;
    -webkit-text-stroke: 1px rgba(255, 255, 255, 0.025);
    white-space: nowrap;
    z-index: 1;
    pointer-events: none;
    letter-spacing: 0.1em;
  }

  .bg-orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(100px);
    z-index: 1;
    pointer-events: none;
  }

  .orb-s1 {
    width: 400px;
    height: 400px;
    background: var(--color-accent);
    opacity: 0.06;
    top: 10%;
    right: -150px;
  }

  .orb-s2 {
    width: 350px;
    height: 350px;
    background: var(--color-accent-secondary);
    opacity: 0.08;
    bottom: 0;
    left: -100px;
  }

  /* Header */
  .services-header {
    text-align: center;
    margin-bottom: 5rem;
  }

  .subtitle {
    font-family: var(--font-mono);
    color: var(--color-text-muted);
    font-size: 1.05rem;
    margin-top: 1rem;
    line-height: 1.6;
    max-width: 600px;
    margin-left: auto;
    margin-right: auto;
  }

  /* Grid — 3 equal columns */
  .services-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
    margin-bottom: 4rem;
  }

  /* Card */
  .service-card {
    position: relative;
    padding: 2.4rem;
    border-radius: 16px;
    overflow: hidden;
    transition: transform 0.35s cubic-bezier(0.175, 0.885, 0.32, 1.275), box-shadow 0.35s ease, border-color 0.35s ease;
    cursor: default;
    display: flex;
    flex-direction: column;
  }

  .service-card:hover {
    transform: translateY(-8px);
    border-color: rgba(0, 229, 255, 0.4);
    box-shadow: 0 20px 50px rgba(0, 229, 255, 0.12);
  }

  /* Featured card accent */
  .service-card.featured {
    border-color: rgba(0, 229, 255, 0.35);
    background: linear-gradient(135deg, rgba(0, 229, 255, 0.06) 0%, rgba(10, 15, 28, 0.6) 60%);
  }

  .featured-label {
    position: absolute;
    top: 1.2rem;
    right: 1.2rem;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-accent);
    border: 1px solid rgba(0, 229, 255, 0.3);
    padding: 0.25rem 0.6rem;
    border-radius: 999px;
    background: rgba(0, 229, 255, 0.08);
  }

  /* Glow on hover */
  .card-glow {
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at 50% 0%, rgba(0, 229, 255, 0.08) 0%, transparent 70%);
    opacity: 0;
    transition: opacity 0.4s ease;
    pointer-events: none;
    border-radius: 16px;
  }

  .featured-glow {
    opacity: 0.6;
  }

  .service-card:hover .card-glow {
    opacity: 1;
  }

  /* Icon */
  .service-icon-wrap {
    margin-bottom: 1.5rem;
  }

  .service-icon {
    width: 52px;
    height: 52px;
    border-radius: 14px;
    background: rgba(0, 229, 255, 0.08);
    border: 1px solid rgba(0, 229, 255, 0.2);
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.3s ease, box-shadow 0.3s ease;
  }

  .service-icon svg {
    width: 26px;
    height: 26px;
    color: var(--color-accent);
  }

  .service-card:hover .service-icon {
    background: rgba(0, 229, 255, 0.15);
    box-shadow: 0 0 20px rgba(0, 229, 255, 0.2);
  }

  /* Text */
  .service-title {
    font-size: 1.3rem;
    color: var(--color-text);
    margin-bottom: 0.8rem;
    font-weight: 700;
  }

  .service-desc {
    font-size: 0.95rem;
    color: var(--color-text-muted);
    line-height: 1.65;
    margin-bottom: 1.4rem;
  }

  /* Feature list */
  .service-features {
    list-style: none;
    padding: 0;
    margin: 0 0 1.5rem 0;
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
    flex: 1;
  }

  .service-features li {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--color-text-muted);
    display: flex;
    align-items: flex-start;
    gap: 0.5rem;
    line-height: 1.4;
  }

  .service-features li::before {
    content: "→";
    color: var(--color-accent);
    font-size: 0.75rem;
    margin-top: 0.1rem;
    flex-shrink: 0;
  }

  /* Tech tags at bottom */
  .service-tag-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
    padding-top: 1.2rem;
    border-top: 1px solid rgba(255, 255, 255, 0.05);
    margin-top: auto;
  }

  .stag {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--color-text-muted);
    border: 1px solid rgba(255, 255, 255, 0.12);
    padding: 0.2rem 0.6rem;
    border-radius: 4px;
    transition: all 0.3s ease;
  }

  .service-card:hover .stag {
    color: var(--color-accent);
    border-color: rgba(0, 229, 255, 0.3);
  }

  /* CTA */
  .services-cta {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 2rem;
    padding: 3rem;
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: 16px;
    background: linear-gradient(135deg, rgba(0, 229, 255, 0.04) 0%, rgba(139, 92, 246, 0.04) 100%);
    flex-direction: column;
  }

  .cta-text {
    font-size: 1.4rem;
    font-weight: 600;
    color: var(--color-text);
    margin: 0;
    text-align: center;
  }

  .cta-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    font-size: 1rem;
  }

  /* Responsive */
  @media (max-width: 1024px) {
    .services-grid {
      grid-template-columns: repeat(2, 1fr);
    }
    .service-card:last-child {
      grid-column: 1 / -1;
      max-width: 500px;
      margin: 0 auto;
      width: 100%;
    }
  }

  @media (max-width: 640px) {
    .services-grid {
      grid-template-columns: 1fr;
    }
    .service-card:last-child {
      grid-column: auto;
      max-width: none;
    }
    .bg-typography {
      font-size: 25vw;
    }
  }
</style>
