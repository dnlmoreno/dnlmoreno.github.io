---
// Hero.astro
---

<section id="hero" class="section hero-section fade-in">
  <div class="container hero-container">
    <div class="hero-top-row">
      <div class="hero-content">
        <div class="badge-row">
          <div class="badge">Machine Learning Engineer & Researcher</div>
          <div class="freelance-badge">
            <span class="fl-dot"></span>
            Available for Freelance
          </div>
        </div>

        <h1 class="hero-title">
          Hello I'm<br />
          <span class="text-accent">Daniel Moreno Cartagena</span>
        </h1>

        <div class="typewriter-container">
          <span id="typewriter" class="typewriter-text"></span><span
            class="cursor">|</span
          >
        </div>

        <p class="hero-description">
          I design and research Deep Learning models for complex data analysis,
          dedicated to developing reliable AI systems that accelerate scientific
          discovery and benefit society.
        </p>

        <div class="hero-actions">
          <a
            href="/CV_oficial.pdf"
            class="btn btn-primary"
            target="_blank"
            rel="noopener noreferrer"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="18"
              height="18"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              ><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"
              ></path><polyline points="7 10 12 15 17 10"></polyline><line
                x1="12"
                y1="15"
                x2="12"
                y2="3"></line></svg
            >
            Download CV
          </a>

          <div class="social-links">
            <a
              href="https://github.com/dnlmoreno"
              target="_blank"
              aria-label="GitHub"
              class="social-icon"
            >
              <svg
                width="24"
                height="24"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                ><path
                  d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"
                ></path></svg
              >
            </a>
            <a
              href="https://linkedin.com/in/danielmorenoc"
              target="_blank"
              aria-label="LinkedIn"
              class="social-icon"
            >
              <svg
                width="24"
                height="24"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                ><path
                  d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"
                ></path><rect x="2" y="9" width="4" height="12"></rect><circle
                  cx="4"
                  cy="4"
                  r="2"></circle></svg
              >
            </a>
            <!--<a href="https://youtube.com/@[PLACEHOLDER]" target="_blank" aria-label="YouTube" class="social-icon">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22.54 6.42a2.78 2.78 0 0 0-1.94-2C18.88 4 12 4 12 4s-6.88 0-8.6.46a2.78 2.78 0 0 0-1.94 2A29 29 0 0 0 1 11.75a29 29 0 0 0 .46 5.33 2.78 2.78 0 0 0 1.94 2c1.72.46 8.6.46 8.6.46s6.88 0 8.6-.46a2.78 2.78 0 0 0 1.94-2 29 29 0 0 0 .46-5.33 29 29 0 0 0-.46-5.33z"></path><polygon points="9.75 15.02 15.5 11.75 9.75 8.48 9.75 15.02"></polygon></svg>
            </a>-->
            <a
              href="https://scholar.google.com/citations?user=WUlT8voAAAAJ&hl=es&authuser=1"
              target="_blank"
              aria-label="Google Scholar"
              class="social-icon"
            >
              <svg
                width="24"
                height="24"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                ><path d="M22 10v6M2 10l10-5 10 5-10 5z"></path><path
                  d="M6 12v5c3 3 9 3 12 0v-5"></path></svg
              >
            </a>
            <a
              href="https://instagram.com/dnlmoreno"
              target="_blank"
              aria-label="Instagram"
              class="social-icon"
            >
              <svg
                width="24"
                height="24"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                ><rect x="2" y="2" width="20" height="20" rx="5" ry="5"
                ></rect><path
                  d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"
                ></path><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"
                ></line></svg
              >
            </a>
          </div>
        </div>
      </div>

      <div class="hero-visual">
        <div class="profile-container">
          <div class="dashed-border"></div>
          <!-- [PLACEHOLDER] Replace with actual profile picture src. Added transparent black-to-dark gradient so PNGs with transparent bg will show the gradient -->
          <img
            src="/images/Foto_chill_atacama.jpeg"
            alt="Daniel Moreno Cartagena"
            class="profile-img"
          />
        </div>
      </div>
    </div>
    <!-- .hero-top-row -->

    <!-- Stats Row at bottom -->

    <div class="stats-container">
      <div class="stat-item">
        <h3 class="stat-number" id="stat-papers">5</h3>
        <p class="stat-label">Years of Experience</p>
      </div>

      <div class="stat-item">
        <h3 class="stat-number" id="stat-venues">2</h3>
        <p class="stat-label">Projects in Progress</p>
      </div>

      <div class="stat-item">
        <h3 class="stat-number" id="stat-first">8</h3>
        <p class="stat-label">Published Papers</p>
      </div>

      <div class="stat-item">
        <h3 class="stat-number" id="stat-progress">3</h3>
        <p class="stat-label">Papers in Progress</p>
      </div>
    </div>
  </div>
</section>

<style>
  /* Ensure Hero fits perfectly into the screen */
  .hero-section {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding-top: 120px; /* Increased offset to avoid navbar clip */
    padding-bottom: 2rem;
  }

  .hero-container {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 4rem;
    height: 100%;
  }

  .hero-top-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    flex: 1; /* Pushes stats to bottom */
  }

  .hero-content {
    flex: 1;
    max-width: 600px;
  }

  .badge-row {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
    margin-bottom: 1rem;
  }

  .badge {
    display: inline-block;
    padding: 0.4rem 1rem 0.4rem 0; /* Removed left padding to perfectly align with Title and Navbar DM logo */
    background-color: transparent;
    color: var(--color-text-muted);
    font-size: 1.05rem;
    font-family: var(--font-mono);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .freelance-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    padding: 0.3rem 0.85rem;
    border: 1px solid rgba(0, 229, 150, 0.4);
    border-radius: 999px;
    background: rgba(0, 229, 150, 0.07);
    color: #00e596;
    font-family: var(--font-mono);
    font-size: 0.90rem;
    letter-spacing: 0.07em;
    text-transform: uppercase;
  }

  .fl-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: #00e596;
    animation: fl-pulse 1.8s ease-out infinite;
  }

  @keyframes fl-pulse {
    0% {
      box-shadow: 0 0 0 0 rgba(0, 229, 150, 0.7);
    }
    70% {
      box-shadow: 0 0 0 7px rgba(0, 229, 150, 0);
    }
    100% {
      box-shadow: 0 0 0 0 rgba(0, 229, 150, 0);
    }
  }

  .hero-title {
    font-size: 3.2rem; /* Reduced from 4.5rem */
    line-height: 1.15;
    margin-bottom: 1rem;
    color: #ffffff; /* Explicitly white for "Hello I'm" */
  }

  .typewriter-container {
    font-size: 1.3rem;
    font-family: var(--font-mono);
    color: var(--color-text-muted);
    margin-bottom: 1.2rem;
    min-height: 3rem; /* Adjusted to accommodate wrapping for longer phrases */
    height: auto;
    line-height: 1.4;
  }

  .cursor {
    color: var(--color-accent);
    animation: blink 1s step-end infinite;
  }

  @keyframes blink {
    0%,
    100% {
      opacity: 1;
    }
    50% {
      opacity: 0;
    }
  }

  .hero-description {
    font-size: 1.15rem;
    color: var(--color-text-muted);
    margin-bottom: 2.5rem;
    max-width: 90%;
    line-height: 1.6;
  }

  .hero-actions {
    display: flex;
    align-items: center;
    gap: 2rem;
  }

  .social-links {
    display: flex;
    gap: 1rem;
  }

  .social-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    border-radius: 50%;
    border: 1px solid rgba(255, 255, 255, 0.1);
    color: var(--color-text-muted);
    transition: all 0.3s ease;
  }

  .social-icon:hover {
    color: var(--color-accent);
    border-color: var(--color-accent);
    box-shadow: 0 0 10px rgba(0, 229, 255, 0.2);
  }

  /* Visual Profiler */
  .hero-visual {
    flex: 1;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .profile-container {
    position: relative;
    width: 380px;
    height: 380px;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .profile-img {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 340px;
    height: 340px;
    border-radius: 50%;
    object-fit: cover;
    z-index: 2;
    /* Gradient background requested by user */
    background: radial-gradient(circle at center, #24242c 0%, #0a0a0a 70%);
  }

  .dashed-border {
    position: absolute;
    width: 100%;
    height: 100%;
    border-radius: 50%;
    /* Create dashed effect like the image reference */
    border: 2px dashed rgba(0, 229, 255, 0.6);
    z-index: 1;
    animation: rotate 25s linear infinite;
  }

  @keyframes rotate {
    from {
      transform: rotate(0deg);
    }
    to {
      transform: rotate(360deg);
    }
  }

  /* Stats full row */
  .stats-container {
    display: flex;
    justify-content: space-between;
    width: 100%;
    padding: 2.5rem 0 1rem;
    border-top: 1px solid rgba(255, 255, 255, 0.05);
  }

  .stat-item {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .stat-number {
    font-size: 4.5rem;
    /* User requested numbers in white */
    color: #ffffff;
    font-weight: 800;
    line-height: 1;
  }

  .stat-label {
    font-size: 1.0rem;
    color: var(--color-text-muted);
    line-height: 1.4;
    text-transform: uppercase;
    font-family: var(--font-mono);
    max-width: 120px;
  }

  .stat-sub {
    font-size: 0.65rem;
    opacity: 0.6;
    text-transform: none;
  }

  @media (max-width: 1024px) {
    .hero-section {
      min-height: auto;
      padding-top: 150px;
    }

    .hero-top-row {
      flex-direction: column;
      text-align: center;
      gap: 3rem;
    }

    .hero-content {
      display: flex;
      flex-direction: column;
      align-items: center;
    }

    .badge-row {
      justify-content: center;
      text-align: center;
    }

    .badge {
      padding: 0.4rem 0.5rem; /* Symmetry for centered layout */
    }

    .hero-description {
      text-align: center;
    }

    .hero-actions {
      flex-direction: column;
      gap: 1.5rem;
    }

    .stats-container {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 2rem;
      padding-top: 3rem;
    }

    .stat-item {
      justify-content: center;
    }
  }

  @media (max-width: 768px) {
    .hero-title {
      font-size: 2.5rem;
    }

    .profile-container {
      width: 280px;
      height: 280px;
    }

    .profile-img {
      width: 250px;
      height: 250px;
    }

    .stat-number {
      font-size: 2.3rem;
    }
  }
</style>

<script>
  // Typewriter Effect
  const phrases = [
    "Passionate about solving high-impact complex problems.",
    "Bridging the gap between theory and practice.",
    "Specialized in AI-driven scientific discovery.",
  ];

  let currentPhraseIndex = 0;
  let isDeleting = false;
  let text = "";
  let typingSpeed = 100;

  const typeWriterElement = document.getElementById("typewriter");

  function type() {
    if (!typeWriterElement) return;

    const currentPhrase = phrases[currentPhraseIndex];

    if (isDeleting) {
      text = currentPhrase.substring(0, text.length - 1);
      typingSpeed = 50;
    } else {
      text = currentPhrase.substring(0, text.length + 1);
      typingSpeed = 100;
    }

    typeWriterElement.textContent = text;

    if (!isDeleting && text === currentPhrase) {
      typingSpeed = 2000; // Pause at end
      isDeleting = true;
    } else if (isDeleting && text === "") {
      isDeleting = false;
      currentPhraseIndex = (currentPhraseIndex + 1) % phrases.length;
      typingSpeed = 500; // Pause before typing next
    }

    setTimeout(type, typingSpeed);
  }

  // CountUp Logic
  const initCountUp = () => {
    // Assuming CountUp is available globally via CDN in BaseLayout
    // @ts-ignore
    if (typeof CountUp !== "undefined") {
      const observer = new IntersectionObserver((entries) => {
        if (entries[0].isIntersecting) {
          // @ts-ignore
          new CountUp("stat-papers", 10, { duration: 2 }).start();
          // @ts-ignore
          new CountUp("stat-first", 5, { duration: 2 }).start();
          // @ts-ignore
          new CountUp("stat-venues", 3, { duration: 2 }).start();
          // @ts-ignore
          new CountUp("stat-progress", 1, { duration: 2 }).start();

          observer.disconnect();
        }
      });

      const statsContainer = document.querySelector(".stats-container");
      if (statsContainer) observer.observe(statsContainer);
    }
  };

  document.addEventListener("DOMContentLoaded", () => {
    type();
    // Tiny timeout to ensure the countup script from CDN is loaded
    setTimeout(initCountUp, 500);
  });
</script>
