---
interface Props {
  isInProgress?: boolean;
}

const { isInProgress = true } = Astro.props;
import { tutorialsData } from "../data/tutorials.js";
---

<section id="tutorials" class="section tutorials-section">
  <!-- Decorative Abstract Typography -->
  <div class="bg-typography right relative-z">TUTORIALS</div>
  <div class="bg-orb orb-1"></div>

  <div class="container relative-z z-10">
    <div class="about-header fade-in">
      <h2 class="section-title">
        Deep Learning <span class="text-accent">Tutorials</span>
      </h2>
      <p class="subtitle">
        Democratizing AI knowledge for astronomers and scientists.
      </p>
    </div>

    {
      isInProgress ? (
        <div class="in-progress-container fade-in">
          <div class="in-progress-card glass">
            <div class="status-badge">
              <span class="status-dot"></span>
              In Progress
            </div>
            <h3>New tutorials on the way</h3>
            <p>I'm recording high-quality content about Transformers, GNNs, and AI for science. Stay tuned for the upcoming releases.</p>
            
            <div class="placeholder-grid">
              {[1, 2, 3].map(() => (
                <div class="placeholder-card glass">
                  <div class="placeholder-thumb"></div>
                  <div class="placeholder-line short"></div>
                  <div class="placeholder-line long"></div>
                </div>
              ))}
            </div>
          </div>
        </div>
      ) : (
        /* 6 Columns Layout Requested by User */
        <div class="tutorials-grid fade-in">
          {
            tutorialsData.map((tut) => (
              <a
                href={tut.url}
                target="_blank"
                rel="noopener noreferrer"
                class="tutorial-card glass"
              >
                <div class="tut-thumb">
                  <img
                    src={
                      tut.image
                        ? tut.image.replace("3b82f6", "00e5ff")
                        : "https://via.placeholder.com/400x225/111111/00e5ff?text=Tutorial"
                    }
                    alt={tut.title}
                    loading="lazy"
                  />
                  <div class="play-overlay">▶</div>
                </div>
                <div class="tut-content">
                  <span class="tut-duration">{tut.duration}</span>
                  <h4 class="tut-title">{tut.title}</h4>
                </div>
              </a>
            ))
          }
        </div>
      )
    }
  </div>
</section>

<style>
  .tutorials-section {
    position: relative;
    padding-top: 110px; /* Reduced from 140px */
    padding-bottom: 2rem;
    overflow: hidden;
  }

  .relative-z {
    position: relative;
  }
  .z-10 {
    z-index: 10;
  }

  .bg-orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
    z-index: 1;
    pointer-events: none;
    opacity: 0.15;
  }

  .orb-1 {
    width: 350px;
    height: 350px;
    background: #0088ff;
    top: 50%;
    left: -150px;
  }

  .bg-typography {
    position: absolute;
    top: 50px;
    right: -10vw;
    font-size: 15vw;
    font-family: var(--font-sans);
    font-weight: 800;
    color: transparent;
    -webkit-text-stroke: 1px rgba(255, 255, 255, 0.03);
    white-space: nowrap;
    z-index: 1;
    pointer-events: none;
    letter-spacing: 0.1em;
  }

  .about-header {
    margin-bottom: 4rem;
  }

  .subtitle {
    font-family: var(--font-mono);
    color: var(--color-text-muted);
    font-size: 1.4rem;
    margin-top: -1.5rem;
  }

  /* In Progress UI */
  .in-progress-container {
    max-width: 900px;
    margin: 0 auto;
  }

  .in-progress-card {
    padding: 4rem 3rem;
    text-align: center;
    border: 1px solid rgba(0, 229, 255, 0.2);
  }

  .status-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.5rem 1.2rem;
    background: rgba(0, 229, 255, 0.1);
    color: var(--color-accent);
    border-radius: 50px;
    font-family: var(--font-mono);
    font-size: 1rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 2rem;
    border: 1px solid rgba(0, 229, 255, 0.2);
  }

  .status-dot {
    width: 8px;
    height: 8px;
    background: var(--color-accent);
    border-radius: 50%;
    box-shadow: 0 0 10px var(--color-accent);
    animation: pulse 2s infinite;
  }

  @keyframes pulse {
    0% { transform: scale(1); opacity: 1; }
    50% { transform: scale(1.5); opacity: 0.5; }
    100% { transform: scale(1); opacity: 1; }
  }

  .in-progress-card h3 {
    font-size: 2.2rem;
    margin-bottom: 1.5rem;
    color: #fff;
  }

  .in-progress-card p {
    font-size: 1.3rem;
    color: var(--color-text-muted);
    max-width: 600px;
    margin: 0 auto 3rem;
    line-height: 1.6;
  }

  .placeholder-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
    opacity: 0.4;
  }

  .placeholder-card {
    padding: 1rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .placeholder-thumb {
    width: 100%;
    aspect-ratio: 16/9;
    background: rgba(255, 255, 255, 0.05);
    border-radius: 4px;
    position: relative;
    overflow: hidden;
  }

  .placeholder-thumb::after {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.05), transparent);
    animation: shimmer 2s infinite;
  }

  @keyframes shimmer {
    0% { transform: translateX(-100%); }
    100% { transform: translateX(100%); }
  }

  .placeholder-line {
    height: 10px;
    background: rgba(255, 255, 255, 0.05);
    border-radius: 2px;
  }

  .placeholder-line.short { width: 40%; }
  .placeholder-line.long { width: 80%; }

  /* Exactly 6 columns requested by user */
  .tutorials-grid {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: 1.5rem;
  }

  .tutorial-card {
    border-radius: 8px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    border: 1px solid rgba(255, 255, 255, 0.05);
    transition:
      transform 0.3s ease,
      border-color 0.3s ease;
    text-decoration: none;
    color: inherit;
  }

  .tutorial-card:hover {
    transform: translateY(-5px);
    border-color: var(--color-accent);
    box-shadow: 0 5px 20px rgba(0, 229, 255, 0.15);
  }

  .tut-thumb {
    position: relative;
    width: 100%;
    padding-bottom: 56.25%; /* 16:9 Aspect Ratio */
    background: #111;
    overflow: hidden;
  }

  .tut-thumb img {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }

  .tutorial-card:hover .tut-thumb img {
    transform: scale(1.05);
  }

  .play-overlay {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 30px;
    height: 30px;
    background-color: rgba(10, 10, 10, 0.8);
    color: var(--color-text);
    display: flex;
    justify-content: center;
    align-items: center;
    border-radius: 50%;
    border: 1.5px solid var(--color-accent);
    font-size: 0.8rem;
    transition: all 0.3s ease;
    z-index: 2;
  }

  .tutorial-card:hover .play-overlay {
    background-color: var(--color-accent);
    color: var(--color-bg);
    transform: translate(-50%, -50%) scale(1.1);
  }

  .tut-content {
    padding: 0.8rem;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .tut-duration {
    font-size: 0.85rem;
    font-family: var(--font-mono);
    color: var(--color-accent);
  }

  .tut-title {
    font-size: 1.05rem;
    line-height: 1.3;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* Responsiveness for 6 cols */
  @media (max-width: 1400px) {
    .tutorials-grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }
  @media (max-width: 1024px) {
    .tutorials-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
  @media (max-width: 768px) {
    .tutorials-grid {
      grid-template-columns: repeat(2, 1fr);
    }
    
    .placeholder-grid {
      grid-template-columns: 1fr;
    }
  }
  @media (max-width: 480px) {
    .tutorials-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

