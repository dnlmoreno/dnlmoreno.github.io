---
import { tutorialsData } from '../data/tutorials.js';
---

<section id="tutorials" class="section tutorials-section">
  <!-- Decorative Abstract Typography -->
  <div class="bg-typography right relative-z">TUTORIALS</div>
  <div class="bg-orb orb-1"></div>
  
  <div class="container relative-z z-10">
    <div class="about-header fade-in">
      <h2 class="section-title">Deep Learning <span class="text-accent">Tutorials</span></h2>
      <p class="subtitle">Democratizing AI knowledge for astronomers and scientists.</p>
    </div>
    
    <!-- 6 Columns Layout Requested by User -->
    <div class="tutorials-grid fade-in">
      {tutorialsData.map(tut => (
        <a href={tut.url} target="_blank" rel="noopener noreferrer" class="tutorial-card glass">
          <div class="tut-thumb">
            <img src={tut.image ? tut.image.replace("3b82f6", "00e5ff") : "https://via.placeholder.com/400x225/111111/00e5ff?text=Tutorial"} alt={tut.title} loading="lazy" />
            <div class="play-overlay">▶</div>
          </div>
          <div class="tut-content">
            <span class="tut-duration">{tut.duration}</span>
            <h4 class="tut-title">{tut.title}</h4>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .tutorials-section {
    position: relative;
    padding-top: 110px; /* Reduced from 140px */
    padding-bottom: 2rem;
    overflow: hidden;
  }

  .relative-z { position: relative; }
  .z-10 { z-index: 10; }

  .bg-orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
    z-index: 1;
    pointer-events: none;
    opacity: 0.15;
  }

  .orb-1 {
    width: 350px;
    height: 350px;
    background: #0088ff;
    top: 50%;
    left: -150px;
  }

  .bg-typography {
    position: absolute;
    top: 50px;
    right: -10vw;
    font-size: 15vw;
    font-family: var(--font-sans);
    font-weight: 800;
    color: transparent;
    -webkit-text-stroke: 1px rgba(255, 255, 255, 0.03);
    white-space: nowrap;
    z-index: 1;
    pointer-events: none;
    letter-spacing: 0.1em;
  }

  .about-header {
    margin-bottom: 4rem;
  }
  
  .subtitle {
    font-family: var(--font-mono);
    color: var(--color-text-muted);
    font-size: 1.1rem;
    margin-top: -1.5rem;
  }

  /* Exactly 6 columns requested by user */
  .tutorials-grid {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: 1.5rem;
  }

  .tutorial-card {
    border-radius: 8px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    border: 1px solid rgba(255, 255, 255, 0.05);
    transition: transform 0.3s ease, border-color 0.3s ease;
    text-decoration: none;
    color: inherit;
  }

  .tutorial-card:hover {
    transform: translateY(-5px);
    border-color: var(--color-accent);
    box-shadow: 0 5px 20px rgba(0, 229, 255, 0.15);
  }

  .tut-thumb {
    position: relative;
    width: 100%;
    padding-bottom: 56.25%; /* 16:9 Aspect Ratio */
    background: #111;
    overflow: hidden;
  }

  .tut-thumb img {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }

  .tutorial-card:hover .tut-thumb img {
    transform: scale(1.05);
  }

  .play-overlay {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 30px;
    height: 30px;
    background-color: rgba(10, 10, 10, 0.8);
    color: var(--color-text);
    display: flex;
    justify-content: center;
    align-items: center;
    border-radius: 50%;
    border: 1.5px solid var(--color-accent);
    font-size: 0.8rem;
    transition: all 0.3s ease;
    z-index: 2;
  }

  .tutorial-card:hover .play-overlay {
    background-color: var(--color-accent);
    color: var(--color-bg);
    transform: translate(-50%, -50%) scale(1.1);
  }

  .tut-content {
    padding: 0.8rem;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .tut-duration {
    font-size: 0.65rem;
    font-family: var(--font-mono);
    color: var(--color-accent);
  }

  .tut-title {
    font-size: 0.85rem;
    line-height: 1.3;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* Responsiveness for 6 cols */
  @media (max-width: 1400px) {
    .tutorials-grid { grid-template-columns: repeat(4, 1fr); }
  }
  @media (max-width: 1024px) {
    .tutorials-grid { grid-template-columns: repeat(3, 1fr); }
  }
  @media (max-width: 768px) {
    .tutorials-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 480px) {
    .tutorials-grid { grid-template-columns: 1fr; }
  }
</style>
