---

<section id="news" class="section news-section">
  <!-- Decorative Abstract Typography -->
  <div class="bg-typography right relative-z">NEWS</div>
  <div class="bg-orb orb-1"></div>

  <div class="container relative-z z-10">
    <div class="about-header text-center fade-in">
      <h2 class="section-title">
        Latest <span class="text-accent">News</span>
      </h2>
      <p class="subtitle">
        Timeline of my recent milestones, talks, and announcements.
      </p>
    </div>

    <div class="timeline fade-in">
      <!-- Item 1: Right -->
      <div class="timeline-item right">
        <div class="timeline-content glass">
          <span class="news-date">August 2026</span>
          <h4 class="news-title">Paper Accepted at ICML</h4>
          <p class="news-desc">
            Our novel Vision Transformer approach for Time Series was accepted.
          </p>
        </div>
      </div>

      <!-- Item 2: Left -->
      <div class="timeline-item left">
        <div class="timeline-content glass">
          <span class="news-date">June 2026</span>
          <h4 class="news-title">Speaker at LARIM</h4>
          <p class="news-desc">
            Presented research on Semi-Supervised Domain Adaptation in front of
            500+ attendees.
          </p>
        </div>
      </div>

      <!-- Item 3: Right -->
      <div class="timeline-item right">
        <div class="timeline-content glass">
          <span class="news-date">January 2026</span>
          <h4 class="news-title">New Tutorial Series Released</h4>
          <p class="news-desc">
            Deep Learning for Astronomy full course published on YouTube to
            democratize AI.
          </p>
        </div>
      </div>

      <!-- Item 4: Left -->
      <div class="timeline-item left">
        <div class="timeline-content glass">
          <span class="news-date">November 2025</span>
          <h4 class="news-title">Research Grant Awarded</h4>
          <p class="news-desc">
            Received funding for computational modeling of synthetic variable
            star populations.
          </p>
        </div>
      </div>

      <!-- Item 5: Right -->
      <div class="timeline-item right">
        <div class="timeline-content glass">
          <span class="news-date">September 2025</span>
          <h4 class="news-title">Join the Lab</h4>
          <p class="news-desc">
            Started my new position as a Machine Learning Engineer handling
            massive photometric data.
          </p>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .news-section {
    position: relative;
    padding-top: 110px; /* Reduced to push items higher */
    padding-bottom: 2rem;
    overflow: hidden;
  }

  .relative-z {
    position: relative;
  }
  .z-10 {
    z-index: 10;
  }

  .bg-orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
    z-index: 1;
    pointer-events: none;
    opacity: 0.15;
  }

  .orb-1 {
    width: 350px;
    height: 350px;
    background: var(--color-accent);
    top: 50%;
    left: -150px;
  }

  .bg-typography {
    position: absolute;
    top: 50px;
    right: -10vw;
    font-size: 15vw;
    font-family: var(--font-sans);
    font-weight: 800;
    color: transparent;
    -webkit-text-stroke: 1px rgba(255, 255, 255, 0.03);
    white-space: nowrap;
    z-index: 1;
    pointer-events: none;
    letter-spacing: 0.1em;
  }

  .about-header {
    margin-bottom: 5rem;
  }

  .subtitle {
    font-family: var(--font-mono);
    color: var(--color-text-muted);
    font-size: 1.4rem;
    margin-top: -1.5rem;
  }

  /* Creative Timeline Style */
  .timeline {
    position: relative;
    max-width: 900px;
    margin: 0 auto;
  }

  /* Center Neon Line */
  .timeline::after {
    content: "";
    position: absolute;
    width: 2px;
    background: linear-gradient(
      to bottom,
      transparent,
      var(--color-accent),
      transparent
    );
    top: 0;
    bottom: 0;
    left: 50%;
    margin-left: -1px;
    border-radius: 4px;
    box-shadow: 0 0 15px var(--color-accent);
  }

  .timeline-item {
    position: relative;
    width: 50%;
    padding: 10px 40px;
    margin-bottom: 2rem;
  }

  /* Timeline Dot */
  .timeline-item::after {
    content: "";
    position: absolute;
    width: 20px;
    height: 20px;
    background: var(--color-bg);
    border: 4px solid var(--color-accent);
    top: 25px;
    border-radius: 50%;
    z-index: 2;
    box-shadow: 0 0 10px var(--color-accent);
    transition: transform 0.3s ease;
  }

  .timeline-item:hover::after {
    transform: scale(1.3);
    background: var(--color-accent);
  }

  /* Positioning */
  .left {
    left: 0;
  }

  .right {
    left: 50%;
  }

  /* Fix dot positions based on side */
  .left::after {
    right: -10px;
  }

  .right::after {
    left: -10px;
  }

  .timeline-content {
    padding: 2rem;
    border-radius: 12px;
    position: relative;
    border: var(--surface-border);
    transition:
      transform 0.3s ease,
      border-color 0.3s ease,
      box-shadow 0.3s ease;
  }

  .timeline-content:hover {
    transform: translateY(-5px);
    border-color: var(--color-accent);
  }

  /* Arrow pointing to line */
  .timeline-content::after {
    content: "";
    position: absolute;
    top: 25px;
    width: 0;
    height: 0;
    border: 12px solid transparent;
  }

  .left .timeline-content::after {
    right: -24px;
    border-left-color: rgba(10, 10, 10, 0.7);
  }

  .right .timeline-content::after {
    left: -24px;
    border-right-color: rgba(10, 10, 10, 0.7);
  }

  .news-date {
    display: inline-block;
    padding: 0.3rem 0.8rem;
    border-radius: 50px;
    background: rgba(0, 229, 255, 0.1);
    font-family: var(--font-mono);
    font-size: 1.0rem;
    color: var(--color-accent);
    margin-bottom: 1rem;
    border: 1px solid rgba(0, 229, 255, 0.2);
  }

  .news-title {
    font-size: 1.6rem;
    margin-bottom: 1rem;
    line-height: 1.3;
  }

  .news-desc {
    font-size: 1.2rem;
    color: var(--color-text-muted);
  }

  /* Mobile Timeline */
  @media (max-width: 768px) {
    .timeline::after {
      left: 31px;
    }

    .timeline-item {
      width: 100%;
      padding-left: 80px;
      padding-right: 0;
    }

    .right {
      left: 0%;
    }

    .left::after,
    .right::after {
      left: 21px;
    }

    .left .timeline-content::after,
    .right .timeline-content::after {
      left: -24px;
      right: auto;
      border-left-color: transparent;
      border-right-color: rgba(10, 10, 10, 0.7);
    }
  }
</style>
